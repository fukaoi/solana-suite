{
  "name": "solana-suite",
  "main": "dist/solana-suite.js",
  "module": "dist/solana-suite.js",
  "types": "lib/index.d.ts",
  "version": "0.0.1",
  "engines": {
    "node": ">=14.*"
  },
  "files": [
    "src",
    "tsconfig.json",
    "package-lock.json"
  ],
  "scripts": {
    "build3": "npx esbuild --bundle src/index.ts --target=esnext --external:'fs' --external:'path'  --outdir=esm/ --define:global=window --define:process.env=window",
    "build2": "tsc && webpack --config webpack.config.js",
    "build": "tsc && sed -i -e 's/\"network\":.*\"/\"network\": \"devnet\"/' tsconfig.json",
    "build.prd": "tsc && sed -i -e 's/\"network\":.*\"/\"network\": \"mainnet-beta\"/' tsconfig.json",
    "test": "mocha -t 300000 --require ts-node/register -- ",
    "test-all": "mocha -t 300000 --require ts-node/register 'test/**/*.test.ts'",
    "lint": "npx tslint --fix --project .",
    "docs": "typedoc src/ --name solana-suite",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@solana/buffer-layout": "^3.0.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.29.2",
    "@tsconfig/node14": "^1.0.1",
    "@tsconfig/recommended": "^1.0.1",
    "@types/bs58": "^4.0.1",
    "@types/chai": "^4.2.21",
    "@types/mocha": "^8.2.3",
    "@types/node": "^14.17.5",
    "@types/python-struct": "^1.0.0",
    "esbuild": "^0.14.2",
    "form-data": "^4.0.0",
    "nft.storage": "^3.3.0",
    "node-fetch": "^3.0.0",
    "ts-loader": "^9.2.6",
    "typescript": "^4.4.3",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1",
    "webpack-merge": "^5.8.0"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^8.4.0",
    "ts-jest": "^27.0.5",
    "ts-node": "^9.1.1",
    "tslib": "^1.14.1",
    "tslint": "^6.1.3",
    "typedoc": "^0.22.4",
    "typedoc-plugin-markdown": "^3.10.4"
  }
}
