{
  "compilerOptions": {
    "lib": [
      "ES6",
      "ES2017",
      "ESNext"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./lib",
    "module": "UMD",
    "target": "ES6",
    "declaration": true,
    "allowJs": true,
    "sourceMap": true,
    "resolveJsonModule": false
  },
  "include": [
    "src/**/**.ts"
  ],
  "solanaSuite": {
    "network": "devnet",
    "debugging": false
  }
}
