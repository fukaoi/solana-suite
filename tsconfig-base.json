{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "src",
    "declaration": true,
    "esModuleInterop": true,
    "lib": [
      "ESNext"
    ],
    "moduleResolution": "node",
    "noFallthroughCasesInSwitch": true,
    "strict": true,
    "skipLibCheck": true,
    "pretty": true,
    "forceConsistentCasingInFileNames": true,
    "traceResolution": false,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compileOnSave": false,
  "solanaSuite": {
    "network": "devnet",
    "debugging": false
  }
}
